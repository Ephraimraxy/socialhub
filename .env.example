# App
PORT=3000
NODE_ENV=production
APP_BASE_URL=https://your-railway-domain.up.railway.app
AUTH_SECRET=replace_with_a_long_random_secret
PLATFORM_ADMIN_EMAIL=owner@example.com
DATA_DIR=data
ENABLE_DIRECT_PUBLISHING=false

# Billing: Paystack first for Nigerian launch
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Future optional billing provider
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI generation
# Claude model, ElevenLabs model, and ElevenLabs voice are selected in the admin UI.
ANTHROPIC_API_KEY=replace_me
ELEVENLABS_API_KEY=replace_me
VIDEO_RENDER_ENDPOINT=https://your-render-worker.example.com/render
VIDEO_RENDER_API_KEY=replace_me

# Social platform OAuth
OAUTH_ENCRYPTION_KEY=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
META_APP_ID=replace_me
META_APP_SECRET=replace_me
TIKTOK_CLIENT_KEY=replace_me
TIKTOK_CLIENT_SECRET=replace_me

# Storage and jobs
DATABASE_URL=postgresql://user:password@host:5432/social_ai_studio
REDIS_URL=redis://default:password@host:6379
R2_ACCESS_KEY_ID=""
R2_ACCOUNT_ID=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
R2_SECRET_ACCESS_KEY=""
